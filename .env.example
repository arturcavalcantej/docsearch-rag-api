# Database
DATABASE_URL=postgresql+psycopg://rag:rag@localhost:5432/rag

# LLM Provider: "openai" ou "gemini"
LLM_PROVIDER=gemini

# OpenAI (pago)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Gemini (gratuito - https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Storage: "local" ou "s3"
STORAGE_BACKEND=local

# AWS (apenas se STORAGE_BACKEND=s3 ou USE_SQS=true)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=seu-bucket-rag

# SQS (processamento assincrono)
USE_SQS=false
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/rag-ingest-queue
